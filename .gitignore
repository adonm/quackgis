# Rust build output
/target/
**/target/

# Spike build cache (spike is a standalone throwaway crate, not a workspace member)
/spike/m00-wire-spike/target/

# Local dev output (DuckLake catalogs, benchmark parquet, spill files, build cache)
/build/

# Local reference clones used during development (kept inside the trust
# boundary per the agent trust model — never commit this directory).
/.tmp/

# A packaged extension can be emitted anywhere; always ignore by extension.
*.duckdb_extension

# Editor / OS
*.swp
**/*.rs.bk
Cargo.lock.bak
.DS_Store

# v0.1 leftovers if they reappear
pg_geometry/*.so
core.*
