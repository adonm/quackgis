+static bool
+duckdb_can_pushdown_limit(PlannerInfo *root, RelOptInfo *baserel)
+{
+    Query *query = root->parse;
+    DuckDBFdwRelationInfo *fpinfo;
+    Const *limit_count;
+    RangeTblRef *from_ref;
+
+    if (!IS_SIMPLE_REL(baserel) || baserel->fdw_private == NULL ||
+        query->jointree == NULL ||
+        list_length(query->jointree->fromlist) != 1 ||
+        !IsA(linitial(query->jointree->fromlist), RangeTblRef))
+        return false;
+
+    from_ref = (RangeTblRef *) linitial(query->jointree->fromlist);
+    if (from_ref->rtindex != baserel->relid)
+        return false;
+
+    fpinfo = (DuckDBFdwRelationInfo *) baserel->fdw_private;
+    if (fpinfo->local_conds != NIL || query->commandType != CMD_SELECT ||
+        query->limitCount == NULL || query->limitOffset != NULL ||
+        query->limitOption != LIMIT_OPTION_COUNT ||
+        query->sortClause != NIL || query->distinctClause != NIL ||
+        query->groupClause != NIL || query->groupingSets != NIL ||
+        query->havingQual != NULL || query->windowClause != NIL ||
+        query->setOperations != NULL || query->rowMarks != NIL ||
+        query->hasAggs || query->hasWindowFuncs || query->hasTargetSRFs ||
+        query->hasSubLinks ||
+        !IsA(query->limitCount, Const))
+        return false;
+
+    limit_count = (Const *) query->limitCount;
+    return limit_count->consttype == INT8OID && !limit_count->constisnull;
+}
