+static Oid
+duckdb_postgis_namespace_oid(void)
+{
+    Oid extension_oid = get_extension_oid("postgis", true);
+
+    if (!OidIsValid(extension_oid))
+        return InvalidOid;
+    return get_extension_schema(extension_oid);
+}
+
+static Oid
+duckdb_postgis_type_oid(const char *typname)
+{
+    Oid namespace_oid = duckdb_postgis_namespace_oid();
+
+    if (!OidIsValid(namespace_oid))
+        return InvalidOid;
+    return GetSysCacheOid2(TYPENAMENSP, Anum_pg_type_oid,
+                           CStringGetDatum(typname),
+                           ObjectIdGetDatum(namespace_oid));
+}
+
+static Oid
+duckdb_postgis_function_oid(Oid namespace_oid, const char *funcname,
+                            int nargs, Oid *argtypes)
+{
+    char *namespace_name;
+    List *qualified_name;
+    Oid function_oid;
+
+    namespace_name = get_namespace_name(namespace_oid);
+    if (namespace_name == NULL)
+        return InvalidOid;
+    qualified_name = list_make2(makeString(namespace_name),
+                                makeString(pstrdup(funcname)));
+    function_oid = LookupFuncName(qualified_name, nargs, argtypes, true);
+    list_free_deep(qualified_name);
+    return function_oid;
+}
+
+static bool
+duckdb_match_bbox_clause(PlannerInfo *root, RelOptInfo *baserel,
+                         Expr *expr, DuckDBBboxClause *bbox)
+{
+    OpExpr *op;
+    FuncExpr *function;
+    List *args;
+    Expr *left;
+    Expr *right;
+    Var *geom_var;
+    Const *geom_const;
+    HeapTuple operator_tuple;
+    Form_pg_operator operator_form;
+    HeapTuple function_tuple;
+    Form_pg_proc function_form;
+    Oid geometry_oid;
+    Oid box2d_oid;
+    Oid namespace_oid;
+    Oid argtypes[1];
+    Oid srid_function;
+    Oid typmod_srid_function;
+    HeapTuple cast_tuple;
+    Form_pg_cast cast_form;
+    Datum box_datum;
+    Oid box_output;
+    bool box_output_varlena;
+    char *box_text;
+    int parsed_length = 0;
+    int column_srid;
+    int constant_srid;
+    RangeTblEntry *rte;
+    DuckDBBboxClause matched;
+
+    if (root == NULL || baserel == NULL || expr == NULL ||
+        !IS_SIMPLE_REL(baserel))
+        return false;
+
+    geometry_oid = duckdb_postgis_type_oid("geometry");
+    namespace_oid = duckdb_postgis_namespace_oid();
+    if (!OidIsValid(geometry_oid) || !OidIsValid(namespace_oid))
+        return false;
+
+    if (IsA(expr, OpExpr))
+    {
+        op = (OpExpr *) expr;
+        operator_tuple = SearchSysCache1(OPEROID, ObjectIdGetDatum(op->opno));
+        if (!HeapTupleIsValid(operator_tuple))
+            return false;
+        operator_form = (Form_pg_operator) GETSTRUCT(operator_tuple);
+        if (strcmp(NameStr(operator_form->oprname), "&&") != 0 ||
+            operator_form->oprleft != geometry_oid ||
+            operator_form->oprright != geometry_oid)
+        {
+            ReleaseSysCache(operator_tuple);
+            return false;
+        }
+        ReleaseSysCache(operator_tuple);
+        args = op->args;
+    }
+    else if (IsA(expr, FuncExpr))
+    {
+        function = (FuncExpr *) expr;
+        function_tuple = SearchSysCache1(
+            PROCOID, ObjectIdGetDatum(function->funcid));
+        if (!HeapTupleIsValid(function_tuple))
+            return false;
+        function_form = (Form_pg_proc) GETSTRUCT(function_tuple);
+        if (strcmp(NameStr(function_form->proname), "st_intersects") != 0 ||
+            function_form->pronamespace != namespace_oid ||
+            function_form->pronargs != 2 ||
+            function_form->proargtypes.values[0] != geometry_oid ||
+            function_form->proargtypes.values[1] != geometry_oid)
+        {
+            ReleaseSysCache(function_tuple);
+            return false;
+        }
+        ReleaseSysCache(function_tuple);
+        args = function->args;
+    }
+    else
+        return false;
+
+    if (list_length(args) != 2)
+        return false;
+    left = (Expr *) linitial(args);
+    right = (Expr *) lsecond(args);
+    if (IsA(left, Var) && IsA(right, Const))
+    {
+        geom_var = (Var *) left;
+        geom_const = (Const *) right;
+    }
+    else if (IsA(left, Const) && IsA(right, Var))
+    {
+        geom_var = (Var *) right;
+        geom_const = (Const *) left;
+    }
+    else
+        return false;
+
+    if (geom_var->varlevelsup != 0 || geom_var->varattno <= 0 ||
+        !bms_is_member(geom_var->varno, baserel->relids) ||
+        geom_var->vartype != geometry_oid || geom_var->vartypmod < 0 ||
+        geom_const->constisnull || geom_const->consttype != geometry_oid)
+        return false;
+
+    rte = planner_rt_fetch(geom_var->varno, root);
+    if (rte->rtekind != RTE_RELATION || !OidIsValid(rte->relid) ||
+        get_atttype(rte->relid, geom_var->varattno) != geometry_oid)
+        return false;
+
+    matched.geom_var = geom_var;
+    matched.minx_attnum = get_attnum(rte->relid, "minx");
+    matched.miny_attnum = get_attnum(rte->relid, "miny");
+    matched.maxx_attnum = get_attnum(rte->relid, "maxx");
+    matched.maxy_attnum = get_attnum(rte->relid, "maxy");
+    if (matched.minx_attnum == InvalidAttrNumber ||
+        matched.miny_attnum == InvalidAttrNumber ||
+        matched.maxx_attnum == InvalidAttrNumber ||
+        matched.maxy_attnum == InvalidAttrNumber ||
+        get_atttype(rte->relid, matched.minx_attnum) != FLOAT8OID ||
+        get_atttype(rte->relid, matched.miny_attnum) != FLOAT8OID ||
+        get_atttype(rte->relid, matched.maxx_attnum) != FLOAT8OID ||
+        get_atttype(rte->relid, matched.maxy_attnum) != FLOAT8OID)
+        return false;
+
+    box2d_oid = duckdb_postgis_type_oid("box2d");
+    if (!OidIsValid(namespace_oid) || !OidIsValid(box2d_oid))
+        return false;
+
+    argtypes[0] = geometry_oid;
+    srid_function = duckdb_postgis_function_oid(
+        namespace_oid, "st_srid", 1, argtypes);
+    argtypes[0] = INT4OID;
+    typmod_srid_function = duckdb_postgis_function_oid(
+        namespace_oid, "postgis_typmod_srid", 1, argtypes);
+    if (!OidIsValid(srid_function) || !OidIsValid(typmod_srid_function))
+        return false;
+
+    column_srid = DatumGetInt32(OidFunctionCall1(
+        typmod_srid_function, Int32GetDatum(geom_var->vartypmod)));
+    constant_srid = DatumGetInt32(OidFunctionCall1(
+        srid_function, geom_const->constvalue));
+    if (column_srid <= 0 || constant_srid != column_srid)
+        return false;
+
+    cast_tuple = SearchSysCache2(CASTSOURCETARGET,
+                                 ObjectIdGetDatum(geometry_oid),
+                                 ObjectIdGetDatum(box2d_oid));
+    if (!HeapTupleIsValid(cast_tuple))
+        return false;
+    cast_form = (Form_pg_cast) GETSTRUCT(cast_tuple);
+    if (!OidIsValid(cast_form->castfunc))
+    {
+        ReleaseSysCache(cast_tuple);
+        return false;
+    }
+    box_datum = OidFunctionCall1(cast_form->castfunc, geom_const->constvalue);
+    ReleaseSysCache(cast_tuple);
+
+    getTypeOutputInfo(box2d_oid, &box_output, &box_output_varlena);
+    box_text = OidOutputFunctionCall(box_output, box_datum);
+    if (sscanf(box_text, "BOX(%lf %lf,%lf %lf)%n",
+               &matched.xmin, &matched.ymin,
+               &matched.xmax, &matched.ymax,
+               &parsed_length) != 4 ||
+        box_text[parsed_length] != '\0' ||
+        !isfinite(matched.xmin) || !isfinite(matched.ymin) ||
+        !isfinite(matched.xmax) || !isfinite(matched.ymax) ||
+        matched.xmin > matched.xmax || matched.ymin > matched.ymax)
+    {
+        pfree(box_text);
+        return false;
+    }
+    pfree(box_text);
+
+    if (bbox != NULL)
+        *bbox = matched;
+    return true;
+}
+
+static void
+duckdb_append_float8_literal(StringInfo buf, double value)
+{
+    Oid output_function;
+    bool output_varlena;
+    char *value_text;
+
+    getTypeOutputInfo(FLOAT8OID, &output_function, &output_varlena);
+    value_text = OidOutputFunctionCall(output_function, Float8GetDatum(value));
+    appendStringInfoString(buf, value_text);
+    pfree(value_text);
+}
+
+static bool
+duckdb_deparse_bbox_clause(Expr *expr, deparse_expr_cxt *context)
+{
+    DuckDBBboxClause bbox;
+    StringInfo buf = context->buf;
+    Index varno;
+
+    if (!duckdb_match_bbox_clause(context->root, context->scanrel,
+                                  expr, &bbox))
+        return false;
+
+    varno = bbox.geom_var->varno;
+    appendStringInfoString(buf, "((");
+    duckdb_deparse_column_ref(buf, varno, bbox.minx_attnum,
+                              context->root, false);
+    appendStringInfoString(buf, " <= ");
+    duckdb_append_float8_literal(buf, bbox.xmax);
+    appendStringInfoString(buf, ") AND (");
+    duckdb_deparse_column_ref(buf, varno, bbox.maxx_attnum,
+                              context->root, false);
+    appendStringInfoString(buf, " >= ");
+    duckdb_append_float8_literal(buf, bbox.xmin);
+    appendStringInfoString(buf, ") AND (");
+    duckdb_deparse_column_ref(buf, varno, bbox.miny_attnum,
+                              context->root, false);
+    appendStringInfoString(buf, " <= ");
+    duckdb_append_float8_literal(buf, bbox.ymax);
+    appendStringInfoString(buf, ") AND (");
+    duckdb_deparse_column_ref(buf, varno, bbox.maxy_attnum,
+                              context->root, false);
+    appendStringInfoString(buf, " >= ");
+    duckdb_append_float8_literal(buf, bbox.ymin);
+    appendStringInfoString(buf, "))");
+    return true;
+}
