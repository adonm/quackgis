# SPDX-License-Identifier: Apache-2.0
apiVersion: v1
kind: Secret
metadata:
  name: quackgis-kind-qgis-tls
  namespace: quackgis
type: kubernetes.io/tls
data:
  tls.crt: @@CLIENT_TLS_CERTIFICATE@@
  tls.key: @@CLIENT_TLS_PRIVATE_KEY@@
  ca.crt: @@TLS_CA_CERTIFICATE@@
---
apiVersion: batch/v1
kind: Job
metadata:
  name: quackgis-qgis
  namespace: quackgis
spec:
  backoffLimit: 0
  ttlSecondsAfterFinished: 600
  template:
    metadata:
      labels:
        app.kubernetes.io/name: quackgis-qgis
    spec:
      restartPolicy: Never
      securityContext:
        fsGroup: 65532
        fsGroupChangePolicy: OnRootMismatch
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: qgis
          image: "@@QGIS_IMAGE@@"
          imagePullPolicy: IfNotPresent
          command: ["/bin/bash", "-ceu"]
          args:
            - |-
              export HOME=/tmp/qgis-home
              export QT_QPA_PLATFORM=offscreen
              mkdir -p "$HOME/.postgresql"
              cp /etc/quackgis/tls/ca.crt "$HOME/.postgresql/root.crt"
              cp /etc/quackgis/tls/tls.crt "$HOME/.postgresql/postgresql.crt"
              cp /etc/quackgis/tls/tls.key "$HOME/.postgresql/postgresql.key"
              chmod 600 "$HOME/.postgresql/postgresql.key"
              python3 - <<'PY'
              from qgis.PyQt.QtCore import QSize
              from qgis.PyQt.QtGui import QColor
              from qgis.core import (
                  Qgis,
                  QgsApplication,
                  QgsDataSourceUri,
                  QgsFeatureRequest,
                  QgsMapRendererParallelJob,
                  QgsMapSettings,
                  QgsMarkerSymbol,
                  QgsRectangle,
                  QgsSingleSymbolRenderer,
                  QgsVectorLayer,
              )

              assert Qgis.QGIS_VERSION == "3.44.11-Solothurn", Qgis.QGIS_VERSION
              app = QgsApplication([], False)
              app.initQgis()
              try:
                  uri = QgsDataSourceUri()
                  uri.setConnection(
                      "quackgis.quackgis.svc.cluster.local",
                      "5432",
                      "quackgis",
                      "postgres",
                      "",
                      QgsDataSourceUri.SslVerifyFull,
                  )
                  uri.setUseEstimatedMetadata(True)
                  uri.setDataSource(
                      "",
                      "(SELECT id, name, geom_wkb FROM public.kind_psycopg_points)",
                      "geom_wkb",
                      "",
                      "id",
                  )
                  layer = QgsVectorLayer(uri.uri(False), "kind_psycopg_points", "postgres")
                  assert layer.isValid(), layer.error().message()
                  fields = [field.name() for field in layer.fields()]
                  assert fields == ["id", "name"], fields
                  assert layer.featureCount() == 2
                  features = list(layer.getFeatures(QgsFeatureRequest().setLimit(2)))
                  values = sorted(
                      (
                          feature["id"],
                          feature["name"],
                          feature.geometry().asWkt() if feature.hasGeometry() else None,
                      )
                      for feature in features
                  )
                  assert values == [(1, "one", "Point (1 2)"), (2, None, None)], values
                  extent = layer.extent()
                  extent_values = (
                      extent.xMinimum(),
                      extent.yMinimum(),
                      extent.xMaximum(),
                      extent.yMaximum(),
                  )
                  assert extent_values == (1.0, 2.0, 1.0, 2.0), extent_values

                  filtered = list(
                      layer.getFeatures(
                          QgsFeatureRequest().setFilterExpression('"id" = 1')
                      )
                  )
                  assert len(filtered) == 1 and filtered[0]["name"] == "one", filtered
                  assert layer.setSubsetString('"id" = 1')
                  subset = list(layer.getFeatures())
                  assert len(subset) == 1 and subset[0]["id"] == 1, subset
                  assert layer.setSubsetString("")

                  identified = list(
                      layer.getFeatures(
                          QgsFeatureRequest().setFilterRect(QgsRectangle(0, 1, 2, 3))
                      )
                  )
                  identified_values = [
                      (feature["id"], feature.geometry().asWkt())
                      for feature in identified
                  ]
                  assert identified_values == [(1, "Point (1 2)")], identified_values

                  layer.setRenderer(
                      QgsSingleSymbolRenderer(
                          QgsMarkerSymbol.createSimple(
                              {"name": "circle", "color": "255,0,0", "size": "8"}
                          )
                      )
                  )
                  settings = QgsMapSettings()
                  settings.setLayers([layer])
                  settings.setExtent(QgsRectangle(0, 1, 2, 3))
                  settings.setOutputSize(QSize(128, 128))
                  settings.setBackgroundColor(QColor("white"))
                  renderer = QgsMapRendererParallelJob(settings)
                  renderer.start()
                  renderer.waitForFinished()
                  image = renderer.renderedImage()
                  assert not image.isNull()
                  assert renderer.errors() == [], renderer.errors()
                  nonwhite_pixels = sum(
                      image.pixelColor(x, y) != QColor("white")
                      for x in range(image.width())
                      for y in range(image.height())
                  )
                  assert nonwhite_pixels > 0, nonwhite_pixels
                  print(
                      "qgis_query_layer_ok version=%s rows=2 geometry=point-null key=id "
                      "filter=true identify=true extent=1,2,1,2 render_pixels=%d"
                      % (Qgis.QGIS_VERSION, nonwhite_pixels)
                  )
              finally:
                  app.exitQgis()
              PY
          resources:
            requests:
              cpu: 250m
              memory: 512Mi
            limits:
              cpu: "2"
              memory: 2Gi
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
            runAsNonRoot: true
            runAsUser: 65532
            runAsGroup: 65532
            seccompProfile:
              type: RuntimeDefault
          volumeMounts:
            - name: tls
              mountPath: /etc/quackgis/tls
              readOnly: true
      volumes:
        - name: tls
          secret:
            secretName: quackgis-kind-qgis-tls
            defaultMode: 288
