# SPDX-License-Identifier: Apache-2.0
apiVersion: v1
kind: Namespace
metadata:
  name: quackgis
---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: quackgis-kind-local
spec:
  capacity:
    storage: 10Gi
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: quackgis-kind-local
  hostPath:
    path: /var/lib/quackgis-kind-local
    type: DirectoryOrCreate
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: quackgis-data
  namespace: quackgis
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: quackgis-kind-local
  volumeName: quackgis-kind-local
  resources:
    requests:
      storage: 10Gi
---
apiVersion: v1
kind: Secret
metadata:
  name: quackgis-tls
  namespace: quackgis
type: kubernetes.io/tls
data:
  tls.crt: @@TLS_CERTIFICATE@@
  tls.key: @@TLS_PRIVATE_KEY@@
  ca.crt: @@TLS_CA_CERTIFICATE@@
---
apiVersion: v1
kind: Secret
metadata:
  name: quackgis-auth
  namespace: quackgis
type: Opaque
data:
  password: @@AUTH_PASSWORD@@
---
apiVersion: v1
kind: Service
metadata:
  name: quackgis
  namespace: quackgis
spec:
  selector:
    app.kubernetes.io/name: quackgis
  ports:
    - name: pgwire
      port: 5432
      targetPort: pgwire
    - name: status
      port: 9090
      targetPort: status
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: quackgis
  namespace: quackgis
spec:
  serviceName: quackgis
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: quackgis
  template:
    metadata:
      labels:
        app.kubernetes.io/name: quackgis
    spec:
      terminationGracePeriodSeconds: 40
      securityContext:
        fsGroup: 999
        fsGroupChangePolicy: OnRootMismatch
        seccompProfile:
          type: RuntimeDefault
      initContainers:
        - name: prepare-local-volume
          image: "@@RUNTIME_IMAGE@@"
          imagePullPolicy: IfNotPresent
          command: ["/bin/sh", "-ceu"]
          args: ["mkdir -p /var/lib/quackgis/data /var/lib/quackgis/tmp && chown -R 999:999 /var/lib/quackgis"]
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
              add: ["CHOWN"]
            runAsUser: 0
            seccompProfile:
              type: RuntimeDefault
          volumeMounts:
            - name: data
              mountPath: /var/lib/quackgis
      containers:
        - name: quackgis
          image: "@@RUNTIME_IMAGE@@"
          imagePullPolicy: IfNotPresent
          ports:
            - name: pgwire
              containerPort: 5434
            - name: status
              containerPort: 9090
          env:
            - name: QUACKGIS_HOST
              value: 0.0.0.0
            - name: QUACKGIS_METRICS_HOST
              value: 0.0.0.0
            - name: QUACKGIS_METRICS_PORT
              value: "9090"
            - name: QUACKGIS_CATALOG_PATH
              value: /var/lib/quackgis/catalog.ducklake
            - name: QUACKGIS_DATA_PATH
              value: /var/lib/quackgis/data
            - name: QUACKGIS_DUCKDB_TEMP_DIRECTORY
              value: /var/lib/quackgis/tmp
            - name: QUACKGIS_TLS_MODE
              value: required
            - name: QUACKGIS_TLS_CERT
              value: /etc/quackgis/tls/tls.crt
            - name: QUACKGIS_TLS_KEY
              value: /etc/quackgis/tls/tls.key
            - name: QUACKGIS_AUTH_MODE
              value: password
            - name: QUACKGIS_READWRITE_USER
              value: postgres
            - name: QUACKGIS_READWRITE_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: quackgis-auth
                  key: password
          resources:
            requests:
              cpu: 250m
              memory: 512Mi
            limits:
              cpu: "2"
              memory: 2Gi
          readinessProbe:
            httpGet:
              path: /readyz
              port: status
            initialDelaySeconds: 2
            periodSeconds: 2
            timeoutSeconds: 2
            failureThreshold: 30
          livenessProbe:
            httpGet:
              path: /healthz
              port: status
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 2
          lifecycle:
            preStop:
              exec:
                command: ["/bin/sh", "-c", "sleep 2"]
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
            readOnlyRootFilesystem: true
            runAsNonRoot: true
            runAsUser: 999
            runAsGroup: 999
          volumeMounts:
            - name: data
              mountPath: /var/lib/quackgis
            - name: tls
              mountPath: /etc/quackgis/tls
              readOnly: true
      volumes:
        - name: data
          persistentVolumeClaim:
            claimName: quackgis-data
        - name: tls
          secret:
            secretName: quackgis-tls
            defaultMode: 288
