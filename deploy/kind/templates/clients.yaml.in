# SPDX-License-Identifier: Apache-2.0
apiVersion: v1
kind: List
items:
  - apiVersion: batch/v1
    kind: Job
    metadata:
      name: quackgis-psql
      namespace: quackgis
    spec:
      backoffLimit: 0
      ttlSecondsAfterFinished: 300
      template:
        metadata:
          labels:
            app.kubernetes.io/name: quackgis-psql
        spec:
          restartPolicy: Never
          containers:
            - name: psql
              image: "@@CLIENT_IMAGE@@"
              imagePullPolicy: IfNotPresent
              command: ["psql"]
              args: ["-v", "ON_ERROR_STOP=1", "-c", "SELECT 1::INTEGER AS ok"]
              env: &pg_environment
                - name: PGHOST
                  value: quackgis.quackgis.svc.cluster.local
                - name: PGPORT
                  value: "5432"
                - name: PGDATABASE
                  value: quackgis
                - name: PGUSER
                  value: postgres
                - name: PGPASSWORD
                  valueFrom:
                    secretKeyRef:
                      name: quackgis-auth
                      key: password
                - name: PGSSLMODE
                  value: verify-full
                - name: PGSSLROOTCERT
                  value: /etc/quackgis/tls/ca.crt
              securityContext: &client_security
                allowPrivilegeEscalation: false
                capabilities:
                  drop: ["ALL"]
                runAsNonRoot: true
                seccompProfile:
                  type: RuntimeDefault
              volumeMounts: &tls_mount
                - name: tls
                  mountPath: /etc/quackgis/tls
                  readOnly: true
          volumes: &tls_volume
            - name: tls
              secret:
                secretName: quackgis-tls
                defaultMode: 292
  - apiVersion: batch/v1
    kind: Job
    metadata:
      name: quackgis-psycopg
      namespace: quackgis
    spec:
      backoffLimit: 0
      ttlSecondsAfterFinished: 300
      template:
        metadata:
          labels:
            app.kubernetes.io/name: quackgis-psycopg
        spec:
          restartPolicy: Never
          containers:
            - name: psycopg
              image: "@@CLIENT_IMAGE@@"
              imagePullPolicy: IfNotPresent
              command: ["python3"]
              args:
                - -c
                - "import psycopg; c=psycopg.connect(''); assert c.execute('SELECT 1::INTEGER').fetchone() == (1,); c.close()"
              env: *pg_environment
              securityContext: *client_security
              volumeMounts: *tls_mount
          volumes: *tls_volume
  - apiVersion: batch/v1
    kind: Job
    metadata:
      name: quackgis-ogr
      namespace: quackgis
    spec:
      backoffLimit: 0
      ttlSecondsAfterFinished: 300
      template:
        metadata:
          labels:
            app.kubernetes.io/name: quackgis-ogr
        spec:
          restartPolicy: Never
          containers:
            - name: ogr
              image: "@@CLIENT_IMAGE@@"
              imagePullPolicy: IfNotPresent
              command: ["ogrinfo"]
              args:
                - "PG:host=quackgis.quackgis.svc.cluster.local port=5432 dbname=quackgis user=postgres sslmode=verify-full sslrootcert=/etc/quackgis/tls/ca.crt"
                - -sql
                - "SELECT 1::INTEGER AS ok"
              env: *pg_environment
              securityContext: *client_security
              volumeMounts: *tls_mount
          volumes: *tls_volume
