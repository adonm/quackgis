# SPDX-License-Identifier: Apache-2.0
apiVersion: v1
kind: Secret
metadata:
  name: quackgis-kind-client-tls
  namespace: quackgis
type: kubernetes.io/tls
data:
  tls.crt: @@CLIENT_TLS_CERTIFICATE@@
  tls.key: @@CLIENT_TLS_PRIVATE_KEY@@
  ca.crt: @@TLS_CA_CERTIFICATE@@
---
apiVersion: v1
kind: Secret
metadata:
  name: quackgis-kind-client-ca
  namespace: quackgis
type: Opaque
data:
  ca.crt: @@TLS_CA_CERTIFICATE@@
---
apiVersion: v1
kind: List
items:
  - apiVersion: batch/v1
    kind: Job
    metadata:
      name: quackgis-psql
      namespace: quackgis
    spec:
      backoffLimit: 0
      ttlSecondsAfterFinished: 300
      template:
        metadata:
          labels:
            app.kubernetes.io/name: quackgis-psql
        spec:
          restartPolicy: Never
          securityContext: &pod_security
            fsGroup: 65532
            fsGroupChangePolicy: OnRootMismatch
            seccompProfile:
              type: RuntimeDefault
          containers:
            - name: psql
              image: "@@CLIENT_IMAGE@@"
              imagePullPolicy: IfNotPresent
              command: ["/bin/sh", "-ceu"]
              args:
                - |-
                  python3 - <<'PY'
                  import time
                  import psycopg
                  deadline = time.monotonic() + 60
                  while time.monotonic() < deadline:
                      try:
                          with psycopg.connect("") as connection:
                              ready = connection.execute("SELECT count(*) = 2 FROM public.kind_psycopg_points").fetchone()[0]
                          if ready:
                              break
                      except psycopg.Error:
                          pass
                      time.sleep(1)
                  else:
                      raise AssertionError("psql describe fixture was not ready")
                  PY
                  psql -X -v ON_ERROR_STOP=1 -c '\d+ public.kind_psycopg_points'
                  echo "psql_describe_copied_data_ok columns=id,name,geom_wkb geometry=geometry"
              env: &pg_environment
                - name: PGHOST
                  value: quackgis.quackgis.svc.cluster.local
                - name: PGPORT
                  value: "5432"
                - name: PGDATABASE
                  value: quackgis
                - name: PGUSER
                  value: postgres
                - name: PGSSLMODE
                  value: verify-full
                - name: PGSSLROOTCERT
                  value: /etc/quackgis/tls/ca.crt
                - name: PGSSLCERT
                  value: /etc/quackgis/tls/tls.crt
                - name: PGSSLKEY
                  value: /etc/quackgis/tls/tls.key
              securityContext: &client_security
                allowPrivilegeEscalation: false
                capabilities:
                  drop: ["ALL"]
                runAsNonRoot: true
                runAsUser: 65532
                runAsGroup: 65532
                seccompProfile:
                  type: RuntimeDefault
              volumeMounts: &tls_mount
                - name: tls
                  mountPath: /etc/quackgis/tls
                  readOnly: true
          volumes: &tls_volume
            - name: tls
              secret:
                secretName: quackgis-kind-client-tls
                defaultMode: 288
  - apiVersion: batch/v1
    kind: Job
    metadata:
      name: quackgis-psycopg
      namespace: quackgis
    spec:
      backoffLimit: 0
      ttlSecondsAfterFinished: 300
      template:
        metadata:
          labels:
            app.kubernetes.io/name: quackgis-psycopg
        spec:
          restartPolicy: Never
          securityContext: *pod_security
          containers:
            - name: psycopg
              image: "@@CLIENT_IMAGE@@"
              imagePullPolicy: IfNotPresent
              command: ["python3"]
              args:
                - -c
                - |-
                  import psycopg
                  table = "public.kind_psycopg_points"
                  with psycopg.connect("", autocommit=True) as connection:
                      connection.execute(f"CREATE TABLE IF NOT EXISTS {table}(id INTEGER, name VARCHAR, geom_wkb BLOB)")
                      connection.execute(f"DELETE FROM {table}")
                      with connection.cursor().copy(f"COPY {table} (id, name, geom_wkb) FROM STDIN") as copy:
                          copy.write_row((1, "one", bytes.fromhex("0101000000000000000000f03f0000000000000040")))
                          copy.write_row((2, None, None))
                  with psycopg.connect("") as reopened:
                      rows = reopened.execute(f"SELECT id, name, CASE WHEN geom_wkb IS NULL THEN NULL ELSE ST_AsText(ST_GeomFromWKB(geom_wkb)) END FROM {table} ORDER BY id").fetchall()
                      assert rows == [(1, "one", "POINT (1 2)"), (2, None, None)], rows
                  print("psycopg_copied_data_ok rows=2 copy=atomic reopen=true")
              env: *pg_environment
              securityContext: *client_security
              volumeMounts: *tls_mount
          volumes: *tls_volume
  - apiVersion: batch/v1
    kind: Job
    metadata:
      name: quackgis-ogr
      namespace: quackgis
    spec:
      backoffLimit: 0
      ttlSecondsAfterFinished: 300
      template:
        metadata:
          labels:
            app.kubernetes.io/name: quackgis-ogr
        spec:
          restartPolicy: Never
          securityContext: *pod_security
          containers:
            - name: ogr
              image: "@@CLIENT_IMAGE@@"
              imagePullPolicy: IfNotPresent
              command: ["/bin/sh", "-ceu"]
              args:
                - |-
                  python3 - <<'PY'
                  import time
                  import psycopg
                  expected = [(1, "one", "POINT (1 2)"), (2, None, None)]
                  deadline = time.monotonic() + 60
                  last = None
                  while time.monotonic() < deadline:
                      try:
                          with psycopg.connect("") as connection:
                              last = connection.execute("SELECT id, name, CASE WHEN geom_wkb IS NULL THEN NULL ELSE ST_AsText(ST_GeomFromWKB(geom_wkb)) END FROM public.kind_psycopg_points ORDER BY id").fetchall()
                          if last == expected:
                              break
                      except psycopg.Error:
                          pass
                      time.sleep(1)
                  else:
                      raise AssertionError(f"copied-data fixture was not ready: {last!r}")
                  PY
                  output_dir="$(mktemp -d)"
                  trap 'rm -rf "$output_dir"' EXIT
                  ogr2ogr -f GeoJSON "$output_dir/readback.geojson" \
                    "PG:host=quackgis.quackgis.svc.cluster.local port=5432 dbname=quackgis user=postgres sslmode=verify-full sslrootcert=/etc/quackgis/tls/ca.crt sslcert=/etc/quackgis/tls/tls.crt sslkey=/etc/quackgis/tls/tls.key" \
                    -sql 'SELECT id, name, ST_GeomFromWKB(geom_wkb) AS "ST_AsEWKB" FROM public.kind_psycopg_points ORDER BY id'
                  python3 - "$output_dir/readback.geojson" <<'PY'
                  import json
                  import sys
                  with open(sys.argv[1], encoding="utf-8") as source:
                      features = json.load(source)["features"]
                  assert features == [
                      {"type": "Feature", "properties": {"id": 1, "name": "one"}, "geometry": {"type": "Point", "coordinates": [1.0, 2.0]}},
                      {"type": "Feature", "properties": {"id": 2, "name": None}, "geometry": None},
                  ], features
                  print("ogr_copied_data_ok rows=2 geometry=point-null cursor=bounded")
                  PY
                  ogr2ogr -f GeoJSON "$output_dir/direct.geojson" \
                    "PG:host=quackgis.quackgis.svc.cluster.local port=5432 dbname=quackgis user=postgres sslmode=verify-full sslrootcert=/etc/quackgis/tls/ca.crt sslcert=/etc/quackgis/tls/tls.crt sslkey=/etc/quackgis/tls/tls.key" \
                    public.kind_psycopg_points
                  python3 - "$output_dir/direct.geojson" <<'PY'
                  import json
                  import sys
                  with open(sys.argv[1], encoding="utf-8") as source:
                      features = json.load(source)["features"]
                  assert features == [
                      {"type": "Feature", "properties": {"id": 1, "name": "one"}, "geometry": {"type": "Point", "coordinates": [1.0, 2.0]}},
                      {"type": "Feature", "properties": {"id": 2, "name": None}, "geometry": None},
                  ], features
                  print("ogr_direct_discovery_ok rows=2 geometry=point-null no_fid=true")
                  PY
              env: *pg_environment
              securityContext: *client_security
              volumeMounts: *tls_mount
          volumes: *tls_volume
  - apiVersion: batch/v1
    kind: Job
    metadata:
      name: quackgis-direct-denied
      namespace: quackgis
    spec:
      backoffLimit: 0
      ttlSecondsAfterFinished: 300
      template:
        metadata:
          labels:
            app.kubernetes.io/name: quackgis-direct-denied
        spec:
          restartPolicy: Never
          securityContext: *pod_security
          containers:
            - name: direct-denied
              image: "@@CLIENT_IMAGE@@"
              imagePullPolicy: IfNotPresent
              command: ["python3"]
              args:
                - -c
                - "import socket; s=socket.socket(); s.settimeout(2); code=s.connect_ex(('quackgis-edge-internal.quackgis.svc.cluster.local', 5434)); s.close(); assert code != 0, 'loopback worker pgwire was reachable directly'"
              securityContext: *client_security
  - apiVersion: batch/v1
    kind: Job
    metadata:
      name: quackgis-plaintext-denied
      namespace: quackgis
    spec:
      backoffLimit: 0
      ttlSecondsAfterFinished: 300
      template:
        metadata:
          labels:
            app.kubernetes.io/name: quackgis-plaintext-denied
        spec:
          restartPolicy: Never
          securityContext: *pod_security
          containers:
            - name: plaintext-denied
              image: "@@CLIENT_IMAGE@@"
              imagePullPolicy: IfNotPresent
              command: ["/bin/sh", "-ceu"]
              args:
                - >-
                  if PGCONNECT_TIMEOUT=3 PGSSLMODE=disable
                  psql -h quackgis.quackgis.svc.cluster.local -p 5432
                  -U postgres -d quackgis -c 'SELECT 1'; then
                    echo 'plaintext tiny-client connection unexpectedly succeeded' >&2; exit 1;
                  fi
              securityContext: *client_security
  - apiVersion: batch/v1
    kind: Job
    metadata:
      name: quackgis-uncredentialed-denied
      namespace: quackgis
    spec:
      backoffLimit: 0
      ttlSecondsAfterFinished: 300
      template:
        metadata:
          labels:
            app.kubernetes.io/name: quackgis-uncredentialed-denied
        spec:
          restartPolicy: Never
          securityContext: *pod_security
          containers:
            - name: uncredentialed-denied
              image: "@@CLIENT_IMAGE@@"
              imagePullPolicy: IfNotPresent
              command: ["/bin/sh", "-ceu"]
              args:
                - >-
                  if PGCONNECT_TIMEOUT=3 PGSSLMODE=verify-full
                  PGSSLROOTCERT=/etc/quackgis/tls/ca.crt
                  psql -h quackgis.quackgis.svc.cluster.local -p 5432
                  -U postgres -d quackgis -c 'SELECT 1'; then
                    echo 'client-certificate-free connection unexpectedly succeeded' >&2; exit 1;
                  fi
              securityContext: *client_security
              volumeMounts:
                - name: ca
                  mountPath: /etc/quackgis/tls
                  readOnly: true
          volumes:
            - name: ca
              secret:
                secretName: quackgis-kind-client-ca
                defaultMode: 292
