index 00000000..a9193c3f
--- /dev/null
+++ b/test/sql/functions/ducklake_column_info.test
@@ -0,0 +1,210 @@
+# name: test/sql/functions/ducklake_column_info.test
+# group: [functions]
+
+require ducklake
+
+require parquet
+
+test-env DUCKLAKE_CONNECTION {TEST_DIR}/ducklake_column_info.db
+
+test-env DATA_PATH {TEST_DIR}
+
+statement ok
+ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_column_info_files')
+
+query TT
+SELECT column_name, column_type
+FROM (DESCRIBE SELECT * FROM ducklake_column_info('ducklake'))
+----
+schema_name	VARCHAR
+schema_id	BIGINT
+schema_uuid	UUID
+table_name	VARCHAR
+table_id	BIGINT
+table_uuid	UUID
+column_name	VARCHAR
+column_id	BIGINT
+
+statement ok
+CREATE SCHEMA ducklake.identity_schema
+
+statement ok
+CREATE SCHEMA ducklake.other_schema
+
+statement ok
+CREATE TABLE ducklake.identity_schema.before_name(
+    id BIGINT NOT NULL,
+    old_column VARCHAR,
+    nested STRUCT(label VARCHAR, values INTEGER[]),
+    tags VARCHAR[]
+)
+
+statement ok
+CREATE TABLE ducklake.other_schema.before_name(id BIGINT)
+
+statement ok
+CREATE VIEW ducklake.identity_schema.identity_view AS
+SELECT id FROM ducklake.identity_schema.before_name
+
+query I
+SELECT count(*)
+FROM ducklake.identity_schema.column_info()
+WHERE schema_name = 'identity_schema' AND table_name = 'before_name'
+----
+4
+
+query I
+SELECT count(*)
+FROM ducklake_column_info('ducklake')
+WHERE schema_name = 'identity_schema'
+  AND table_name = 'before_name'
+  AND column_name IN ('label', 'values', 'element')
+----
+0
+
+query I
+SELECT count(*)
+FROM ducklake_column_info('ducklake')
+WHERE schema_name = 'identity_schema' AND table_name = 'identity_view'
+----
+0
+
+query I
+SELECT count(DISTINCT schema_id) = 2 AND count(DISTINCT schema_uuid) = 2
+FROM ducklake_column_info('ducklake')
+WHERE table_name = 'before_name'
+----
+true
+
+statement ok
+CREATE TEMP TABLE identity_before AS
+SELECT schema_id, schema_uuid, table_id, table_uuid, column_id
+FROM ducklake_column_info('ducklake')
+WHERE schema_name = 'identity_schema' AND table_name = 'before_name' AND column_name = 'old_column'
+
+statement ok
+BEGIN
+
+statement ok
+CREATE SCHEMA ducklake.staged_schema
+
+statement ok
+CREATE TABLE ducklake.staged_schema.staged_table(id INTEGER)
+
+statement ok
+ALTER TABLE ducklake.identity_schema.before_name ADD COLUMN staged_column INTEGER
+
+query I
+SELECT count(*)
+FROM ducklake_column_info('ducklake')
+WHERE schema_name = 'staged_schema' OR column_name = 'staged_column'
+----
+0
+
+statement ok
+ROLLBACK
+
+statement ok
+BEGIN
+
+statement ok
+CREATE SCHEMA ducklake.committed_schema
+
+statement ok
+CREATE TABLE ducklake.committed_schema.committed_table(id INTEGER)
+
+statement ok
+ALTER TABLE ducklake.identity_schema.before_name ADD COLUMN committed_column INTEGER
+
+statement ok
+COMMIT
+
+query I
+SELECT count(*)
+FROM ducklake_column_info('ducklake')
+WHERE (schema_name = 'committed_schema' AND table_name = 'committed_table')
+   OR (schema_name = 'identity_schema' AND table_name = 'before_name' AND column_name = 'committed_column')
+----
+2
+
+statement ok
+ALTER TABLE ducklake.identity_schema.before_name RENAME TO after_name
+
+statement ok
+ALTER TABLE ducklake.identity_schema.after_name RENAME COLUMN old_column TO new_column
+
+statement ok
+ALTER TABLE ducklake.identity_schema.after_name ADD COLUMN added_empty INTEGER
+
+statement ok
+DETACH ducklake
+
+statement ok
+ATTACH 'ducklake:{DUCKLAKE_CONNECTION}' AS ducklake (DATA_PATH '{DATA_PATH}/ducklake_column_info_files')
+
+query IIIII
+SELECT b.schema_id = a.schema_id,
+       b.schema_uuid = a.schema_uuid,
+       b.table_id = a.table_id,
+       b.table_uuid = a.table_uuid,
+       b.column_id = a.column_id
+FROM identity_before b
+JOIN ducklake_column_info('ducklake') a
+  ON a.schema_name = 'identity_schema'
+ AND a.table_name = 'after_name'
+ AND a.column_name = 'new_column'
+----
+true	true	true	true	true
+
+query I
+SELECT count(*)
+FROM ducklake_column_info('ducklake')
+WHERE schema_name = 'identity_schema'
+  AND table_name = 'after_name'
+  AND column_name = 'added_empty'
+----
+1
+
+statement ok
+CREATE TEMP TABLE added_before AS
+SELECT column_id
+FROM ducklake_column_info('ducklake')
+WHERE schema_name = 'identity_schema' AND table_name = 'after_name' AND column_name = 'added_empty'
+
+statement ok
+ALTER TABLE ducklake.identity_schema.after_name DROP COLUMN added_empty
+
+statement ok
+ALTER TABLE ducklake.identity_schema.after_name ADD COLUMN added_empty INTEGER
+
+query I
+SELECT b.column_id <> a.column_id
+FROM added_before b
+JOIN ducklake_column_info('ducklake') a
+  ON a.schema_name = 'identity_schema'
+ AND a.table_name = 'after_name'
+ AND a.column_name = 'added_empty'
+----
+true
+
+statement ok
+CREATE TEMP TABLE identity_after AS
+SELECT table_id, table_uuid
+FROM ducklake_column_info('ducklake')
+WHERE schema_name = 'identity_schema' AND table_name = 'after_name' AND column_name = 'id'
+
+statement ok
+DROP TABLE ducklake.identity_schema.after_name
+
+statement ok
+CREATE TABLE ducklake.identity_schema.after_name(id BIGINT)
+
+query II
+SELECT b.table_id <> a.table_id, b.table_uuid <> a.table_uuid
+FROM identity_after b
+JOIN ducklake_column_info('ducklake') a
+  ON a.schema_name = 'identity_schema'
+ AND a.table_name = 'after_name'
+ AND a.column_name = 'id'
+----
+true	true
