      "stage": "C5",
      "trace_status": "implemented_ducklake_metadata_pgwire",
      "protocol": "extended",
      "consumers": ["psql 18.3", "GDAL/OGR 3.11.5", "QGIS 3.44"],
      "sql": "SELECT d.adrelid, d.adnum, d.adbin, pg_catalog.pg_get_expr(d.adbin, d.adrelid) AS default_expression, pg_catalog.col_description(d.adrelid, d.adnum) AS column_description, pg_catalog.obj_description(d.adrelid, 'pg_class') AS table_description FROM pg_catalog.pg_attrdef d WHERE d.adrelid = $1 ORDER BY d.adnum",
      "parameter_type_oids": [26],
      "expected_columns": [
        { "name": "adrelid", "type_oid": 26, "nullable": false },
        { "name": "adnum", "type_oid": 21, "nullable": false },
        { "name": "adbin", "type_oid": 194, "nullable": false },
