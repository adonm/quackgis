    {
      "id": "structural_not_null_constraint_discovery",
      "stage": "C5",
      "trace_status": "implemented_ducklake_not_null_only_pgwire",
      "protocol": "extended",
      "consumers": ["psql 18.3", "client-neutral catalog contract"],
      "sql": "SELECT c.oid, c.conname, c.connamespace, c.contype, c.condeferrable, c.condeferred, c.convalidated, c.conrelid, c.conindid, c.conparentid, c.confrelid, c.conislocal, c.coninhcount, c.connoinherit, c.conperiod, c.conkey, pg_catalog.pg_get_constraintdef(c.oid, true) AS definition FROM pg_catalog.pg_constraint c WHERE c.conrelid = $1 ORDER BY c.conname",
      "parameter_type_oids": [26],
