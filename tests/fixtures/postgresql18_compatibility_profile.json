  "query_families": [
    {
      "id": "bootstrap_owner_resolution",
      "stage": "C3",
      "trace_status": "required_consistency",
      "protocol": "extended",
      "consumers": ["client-neutral catalog contract"],
      "sql": "SELECT n.nspname, r.rolname FROM pg_catalog.pg_namespace n INNER JOIN pg_catalog.pg_roles r ON r.oid = n.nspowner WHERE n.nspname IN ('pg_catalog', 'public') ORDER BY n.nspname",
      "parameter_type_oids": [],
      "expected_columns": [
        { "name": "nspname", "type_oid": 19, "nullable": false },
        { "name": "rolname", "type_oid": 19, "nullable": false }
      ]
    },
    {
      "id": "tokio_postgres_custom_type_lookup",
      "stage": "C3",
      "trace_status": "captured",
      "protocol": "extended",
      "consumers": ["tokio-postgres", "psycopg-compatible type resolution"],
      "sql": "SELECT t.typname, t.typtype, t.typelem, r.rngsubtype, t.typbasetype, n.nspname, t.typrelid FROM pg_catalog.pg_type t LEFT OUTER JOIN pg_catalog.pg_range r ON r.rngtypid = t.oid INNER JOIN pg_catalog.pg_namespace n ON t.typnamespace = n.oid WHERE t.oid = $1",
      "parameter_type_oids": [26],
      "expected_columns": [
        { "name": "typname", "type_oid": 19, "nullable": false },
        { "name": "typtype", "type_oid": 18, "nullable": false },
        { "name": "typelem", "type_oid": 26, "nullable": false },
        { "name": "rngsubtype", "type_oid": 26, "nullable": true },
        { "name": "typbasetype", "type_oid": 26, "nullable": false },
        { "name": "nspname", "type_oid": 19, "nullable": false },
        { "name": "typrelid", "type_oid": 26, "nullable": false }
      ]
    },
