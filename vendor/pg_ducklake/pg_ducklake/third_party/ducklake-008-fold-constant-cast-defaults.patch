+//! Fold a constant default expression - optionally wrapped in a single cast
+//! decoration, as the parser produces for '...'::TYPE and typed literals like
+//! DATE '2020-01-01' - into a Value of the target column type. Returns false
+//! for expressions that cannot be folded without binding.
+static bool TryFoldConstantDefault(const ParsedExpression &expr, const LogicalType &type, Value &result) {
+	reference<const ParsedExpression> inner(expr);
+	auto column_id = type.id();
+	if (column_id == LogicalTypeId::UNBOUND) {
+		// validation-only call sites pass the parse-stage column type
+		column_id = TransformStringToLogicalTypeId(type.ToString());
+	}
+	if (expr.type == ExpressionType::OPERATOR_CAST) {
+		auto &cast_expr = expr.Cast<CastExpression>();
+		if (cast_expr.try_cast) {
+			// TRY_CAST yields NULL instead of erroring when the cast fails;
+			// honoring that contract would require evaluating the cast
+			// against its (unresolved) target type, so do not fold it
+			return false;
+		}
+		// The decoration's target type is only a parse-stage name (see
+		// TransformTypeName). If the name resolves without a catalog and
+		// names a type OTHER than the column's, the cast is potentially
+		// value-changing (e.g. '3.9'::DOUBLE on an INTEGER column rounds to
+		// 4, while a direct INTEGER cast of '3.9' errors) and cannot be
+		// folded here. If it names the column's own type, or is a spelling
+		// the default-type table does not know (clients deparse spellings
+		// like "double precision"), the decoration is a no-op relative to
+		// the column-type cast below and is dropped.
+		auto decoration_id = TransformStringToLogicalTypeId(cast_expr.cast_type.ToString());
+		if (decoration_id != LogicalTypeId::UNBOUND && column_id != LogicalTypeId::UNBOUND &&
+		    decoration_id != column_id) {
+			return false;
+		}
+		inner = *cast_expr.child;
+	}
+	// Nested casts ('3.9'::DOUBLE::INTEGER) are not folded for the same
+	// reason as mismatched decorations: the inner cast can change the value
+	// and needs its type bound to evaluate. They keep being rejected as
+	// non-literal defaults.
+	if (inner.get().type != ExpressionType::VALUE_CONSTANT) {
+		return false;
+	}
+	result = inner.get().Cast<ConstantExpression>().value;
+	if (column_id == LogicalTypeId::UNBOUND) {
+		// the value is folded again against the resolved column type where
+		// it is actually used
+		return true;
+	}
+	if (type.id() != LogicalTypeId::UNBOUND && type.id() != result.type().id()) {
+		result = result.DefaultCastAs(type);
+	}
+	return true;
+}
