+// Reconcile a string-encoded stat value to a (possibly new) target type. Returns true if the value
+// remains valid under the target type. When ALTER COLUMN ... TYPE and an INSERT commit in the same
+// transaction, the seed stats are legitimately read at the txn-start snapshot (pre-ALTER type) while
+// the new data file carries the post-ALTER type -- no cache key can prevent that mismatch. Casting
+// (e.g. INTEGER 1 -> BIGINT 1) is lossless under DuckLake's widening-only type promotions and keeps
+// the value comparable instead of discarding it, which would null the table-level min/max and let the
+// next commit rebuild them value-wrong (see the StatsCacheKey comment for the read-side consequence).
+static bool ReconcileStatToType(string &value, const LogicalType &target) {
+	Value casted;
+	string error;
+	if (Value(value).DefaultTryCastAs(target, casted, &error) && !casted.IsNull()) {
+		value = casted.ToString();
+		return true;
+	}
+	return false;
+}
